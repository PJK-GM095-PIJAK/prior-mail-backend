# ─────────────────────────────────────────────────────────────
# .env.example — Template for local development
# Copy to .env.local and fill in your values
# NEVER commit .env.local or any file with real secrets
# ─────────────────────────────────────────────────────────────

# --- Database (Supabase Postgres) ---
# Use port 6543 (PgBouncer pooler) to stay within the 60-connection free-tier cap.
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxxx.supabase.co:6543/postgres
# DATABASE_SSL=true is the default. Set to false only for a local plain Postgres (no SSL).
# DATABASE_SSL=false
# DATABASE_POOL_SIZE=5

# --- Supabase ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbG...
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Google OAuth (Gmail) ---
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# --- ML Models ---
# Priority model is hosted on the HuggingFace Hub (free-tier Supabase can't hold
# the ~475MB checkpoint). Form: hf://{repo_id}/{version}. See BACKEND_INTEGRATION_GUIDE.
PRIORITY_MODEL_URI=hf://insanar/priormail-priority/v2.0
PRIORITY_MODEL_REVISION=main
PHISHING_MODEL_URI=supabase://models/phishing/v1/checkpoint.bin

# --- CORS (comma-separated origins allowed to call the API; e.g. the React dev server) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- LLM (for summarization + task extraction) ---
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-xxxxx

# --- App Settings ---
SYNC_INTERVAL_SECONDS=300
LOG_LEVEL=DEBUG
ENVIRONMENT=development
